name: Representative Debug Ops

on:
  workflow_dispatch:
    inputs:
      representative_flavor:
        description: Single flavor to validate
        required: true
        default: kuran_kerim
        type: string
  push:
    branches:
      - main
    paths:
      - 'app/**'
      - 'core/**'
      - 'feature/**'
      - 'buildSrc/**'
      - 'gradle/**'
      - '*.gradle.kts'
      - 'gradle.properties'
      - 'settings.gradle.kts'
      - 'scripts/ci/**'
      - '.github/actions/**'
      - '.github/workflows/representative-debug-ops.yml'

permissions:
  contents: read

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  cancel-in-progress: true

env:
  JAVA_VERSION: '21'
  ANDROID_API_LEVEL: 36
  REPRESENTATIVE_FLAVOR: ${{ github.event.inputs.representative_flavor || 'kuran_kerim' }}
  GRADLE_OPTS: -Dorg.gradle.jvmargs=-Xmx6g -Djava.awt.headless=true -Dorg.gradle.daemon=false -Dksp.incremental=false

jobs:
  debug:
    name: Validate representative Debug flavor
    runs-on: ubuntu-latest
    env:
      FIREBASE_WEB_CLIENT_ID: ${{ secrets.FIREBASE_WEB_CLIENT_ID }}
      FIREBASE_CONFIGS_ZIP_BASE64: ${{ secrets.FIREBASE_CONFIGS_ZIP_BASE64 }}
      CF_R2_ACCOUNT_ID: ${{ secrets.CF_R2_ACCOUNT_ID }}
      CF_API_TOKEN: ${{ secrets.CF_API_TOKEN }}
      CF_R2_BUCKET: ${{ secrets.CF_R2_BUCKET }}
      CF_R2_FIREBASE_OBJECT: ${{ secrets.CF_R2_FIREBASE_OBJECT }}
      CLOUDFLARE_ACCOUNT_ID: ${{ secrets.CLOUDFLARE_ACCOUNT_ID }}
      CLOUDFLARE_API_TOKEN: ${{ secrets.CLOUDFLARE_API_TOKEN }}
    steps:
      - uses: actions/checkout@v6
        with:
          fetch-depth: 1

      - uses: actions/setup-java@v5
        with:
          distribution: temurin
          java-version: ${{ env.JAVA_VERSION }}

      - uses: android-actions/setup-android@v4.0.1
        with:
          accept-android-sdk-licenses: false
          log-accepted-android-sdk-licenses: false

      - name: Install Android SDK packages
        run: |
          set -euo pipefail
          SDK_ROOT="${ANDROID_SDK_ROOT:-$ANDROID_HOME}"
          sdkmanager --sdk_root="$SDK_ROOT" "platform-tools" "platforms;android-${ANDROID_API_LEVEL}" "build-tools;36.0.0"

      - name: Accept Android SDK licenses
        run: |
          set -euo pipefail
          SDK_ROOT="${ANDROID_SDK_ROOT:-$ANDROID_HOME}"
          set +o pipefail
          yes | sdkmanager --licenses --sdk_root="$SDK_ROOT" >/dev/null
          set -o pipefail

      - uses: gradle/actions/setup-gradle@v5

      - name: Resolve flavor name
        run: |
          set -euo pipefail
          flavor="$(printf '%s' "$REPRESENTATIVE_FLAVOR" | tr -d '[:space:]')"
          cap="$(tr '[:lower:]' '[:upper:]' <<< "${flavor:0:1}")${flavor:1}"
          echo "FLAVOR=$flavor" >> "$GITHUB_ENV"
          echo "CAP_FLAVOR=$cap" >> "$GITHUB_ENV"

      - name: Verify env contract
        uses: ./.github/actions/verify-env-contract

      - name: Export firebase env
        uses: ./.github/actions/export-firebase-override-env

      - name: Firebase config override
        uses: ./.github/actions/firebase-config
        with:
          firebase_configs_zip_base64: ${{ env.FIREBASE_CONFIGS_ZIP_BASE64 }}
          cf_r2_account_id: ${{ env.CF_R2_ACCOUNT_ID }}
          cf_api_token: ${{ env.CF_API_TOKEN }}
          cf_r2_bucket: ${{ env.CF_R2_BUCKET }}
          cf_r2_firebase_object: ${{ env.CF_R2_FIREBASE_OBJECT }}

      - name: Validate Google Sign-In Config
        uses: ./.github/actions/verify-google-signin-config
        with:
          flavors: ${{ env.FLAVOR }}

      - name: Static analysis
        run: |
          set -euo pipefail
          chmod +x ./gradlew
          ./gradlew detekt ktlintCheck --stacktrace --no-daemon --max-workers=2

      - name: Lint representative flavor
        run: |
          set -euo pipefail
          ./gradlew "lint${CAP_FLAVOR}Debug" --stacktrace --no-daemon --max-workers=2

      - name: Build representative flavor
        run: |
          set -euo pipefail
          ./gradlew "assemble${CAP_FLAVOR}Debug" --stacktrace --no-daemon --max-workers=2
